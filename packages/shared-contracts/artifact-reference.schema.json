{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Artifact Reference Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_name",
    "artifact_type",
    "artifact_uri",
    "created_at"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_name": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "document",
        "schema",
        "script",
        "repository",
        "report",
        "binary",
        "other"
      ]
    },
    "artifact_uri": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "company_id": {
      "type": "string",
      "minLength": 1
    },
    "produced_by_execution_result_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_note": {
      "type": "string",
      "minLength": 1
    }
  }
}
