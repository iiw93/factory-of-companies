{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Embedding Provider Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "embedding_provider_id",
    "provider_name",
    "provider_type",
    "provider_status",
    "created_at"
  ],
  "properties": {
    "embedding_provider_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_name": {
      "type": "string",
      "minLength": 1
    },
    "provider_type": {
      "type": "string",
      "enum": [
        "local_embedding",
        "cloud_embedding",
        "gemini_embedding",
        "other"
      ]
    },
    "provider_status": {
      "type": "string",
      "enum": [
        "draft",
        "available",
        "limited",
        "deprecated"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "supports_text": {
      "type": "boolean"
    },
    "supports_image": {
      "type": "boolean"
    },
    "supports_audio": {
      "type": "boolean"
    },
    "supports_video": {
      "type": "boolean"
    },
    "supports_pdf": {
      "type": "boolean"
    },
    "default_dimension": {
      "type": "integer",
      "minimum": 1
    },
    "max_dimension": {
      "type": "integer",
      "minimum": 1
    },
    "provider_note": {
      "type": "string",
      "minLength": 1
    }
  }
}
