{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Execution Request Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "execution_request_id",
    "trace_id",
    "command_id",
    "session_id",
    "user_id",
    "target_role",
    "action_type",
    "priority",
    "created_at"
  ],
  "properties": {
    "execution_request_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "command_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "target_role": {
      "type": "string",
      "minLength": 1
    },
    "action_type": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high",
        "critical"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "budget_hint": {
      "type": "number",
      "minimum": 0
    },
    "payload": {
      "type": "object"
    }
  }
}
