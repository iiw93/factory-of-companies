{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Company Context Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "company_id",
    "company_name",
    "company_status",
    "created_at",
    "owner_user_id"
  ],
  "properties": {
    "company_id": {
      "type": "string",
      "minLength": 1
    },
    "company_name": {
      "type": "string",
      "minLength": 1
    },
    "company_status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "paused",
        "archived"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner_user_id": {
      "type": "string",
      "minLength": 1
    },
    "active_project_id": {
      "type": "string",
      "minLength": 1
    },
    "active_session_id": {
      "type": "string",
      "minLength": 1
    },
    "active_trace_id": {
      "type": "string",
      "minLength": 1
    },
    "company_note": {
      "type": "string",
      "minLength": 1
    }
  }
}
