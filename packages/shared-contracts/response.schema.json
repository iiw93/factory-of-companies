{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bridge Response Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "response_id",
    "command_id",
    "channel",
    "user_id",
    "status",
    "message",
    "created_at"
  ],
  "properties": {
    "response_id": {
      "type": "string",
      "minLength": 1
    },
    "command_id": {
      "type": "string",
      "minLength": 1
    },
    "channel": {
      "type": "string",
      "enum": [
        "telegram",
        "dashboard"
      ]
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "accepted",
        "rejected",
        "requires_approval",
        "routed",
        "planned",
        "executing",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "result_type": {
      "type": "string",
      "enum": [
        "acknowledgement",
        "validation_error",
        "approval_request",
        "progress_update",
        "final_result",
        "system_error"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/error"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "field": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object"
        }
      }
    }
  }
}
