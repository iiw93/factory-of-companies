{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Traceability Envelope Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "command_id",
    "session_id",
    "user_id",
    "channel",
    "created_at",
    "current_state"
  ],
  "properties": {
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "command_id": {
      "type": "string",
      "minLength": 1
    },
    "response_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "channel": {
      "type": "string",
      "enum": [
        "telegram",
        "dashboard"
      ]
    },
    "company_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "current_state": {
      "type": "string",
      "enum": [
        "received",
        "validated",
        "rejected",
        "accepted",
        "requires_approval",
        "approved",
        "routed",
        "planned",
        "executing",
        "completed",
        "failed",
        "cancelled"
      ]
    }
  }
}
