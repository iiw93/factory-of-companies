{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Model Routing Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "model_routing_id",
    "routing_name",
    "routing_status",
    "created_at",
    "provider_type",
    "model_class",
    "routing_mode"
  ],
  "properties": {
    "model_routing_id": {
      "type": "string",
      "minLength": 1
    },
    "routing_name": {
      "type": "string",
      "minLength": 1
    },
    "routing_status": {
      "type": "string",
      "enum": [
        "draft",
        "selected",
        "applied",
        "superseded"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_request_id": {
      "type": "string",
      "minLength": 1
    },
    "prompt_package_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_type": {
      "type": "string",
      "enum": [
        "local_llm",
        "cloud_llm",
        "openai",
        "other"
      ]
    },
    "model_class": {
      "type": "string",
      "enum": [
        "reasoning",
        "coding",
        "general",
        "embedding",
        "other"
      ]
    },
    "routing_mode": {
      "type": "string",
      "enum": [
        "local_only",
        "cloud_only",
        "hybrid",
        "fallback"
      ]
    },
    "priority_level": {
      "type": "string",
      "minLength": 1
    },
    "linked_budget_hint_id": {
      "type": "string",
      "minLength": 1
    },
    "linked_timeout_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "routing_note": {
      "type": "string",
      "minLength": 1
    }
  }
}
