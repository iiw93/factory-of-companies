{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Model Routing Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "model_routing_id",
    "routing_name",
    "routing_status",
    "created_at",
    "routing_target_id",
    "provider_name",
    "model_name",
    "routing_mode",
    "contract_version"
  ],
  "properties": {
    "model_routing_id": {
      "type": "string",
      "minLength": 1
    },
    "routing_name": {
      "type": "string",
      "minLength": 1
    },
    "routing_status": {
      "type": "string",
      "enum": [
        "draft",
        "prepared",
        "applied",
        "superseded",
        "archived"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "routing_target_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_name": {
      "type": "string",
      "minLength": 1
    },
    "model_name": {
      "type": "string",
      "minLength": 1
    },
    "routing_mode": {
      "type": "string",
      "enum": [
        "direct",
        "capability_aware",
        "constraint_aware",
        "fallback_chain"
      ]
    },
    "contract_version": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_request_id": {
      "type": "string",
      "minLength": 1
    },
    "prompt_package_id": {
      "type": "string",
      "minLength": 1
    },
    "role_type": {
      "type": "string",
      "minLength": 1
    },
    "action_type": {
      "type": "string",
      "minLength": 1
    },
    "required_capability_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "routing_constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fallback_target_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "linked_tool_invocation_id": {
      "type": "string",
      "minLength": 1
    },
    "routing_note": {
      "type": "string",
      "minLength": 1
    }
  }
}
