{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Approval Action Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approval_action_id",
    "trace_id",
    "command_id",
    "user_id",
    "session_id",
    "decision",
    "created_at"
  ],
  "properties": {
    "approval_action_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "command_id": {
      "type": "string",
      "minLength": 1
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "approve",
        "reject"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "comment": {
      "type": "string",
      "minLength": 1
    }
  }
}
